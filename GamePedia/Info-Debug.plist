<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>APIEnvironment</key>
	<string>$(API_ENVIRONMENT)</string>
	<key>BuildConfiguration</key>
	<string>$(CONFIGURATION)</string>
	<key>BuildFlavor</key>
	<string>$(BUILD_FLAVOR_NAME)</string>
	<key>BuildSchemeName</key>
	<string>$(BUILD_SCHEME_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>GamePedia</string>
	<key>CFBundleName</key>
	<string>GamePedia</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(GOOGLE_REVERSED_CLIENT_ID)</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>gamepedia</string>
			</array>
		</dict>
	</array>
	<key>CommunityGuidelinesURL</key>
	<string>$(COMMUNITY_GUIDELINES_URL)</string>
	<key>CoreBaseURL</key>
	<string>$(CORE_BASE_URL)</string>
	<key>DevDeviceAPIBaseURL</key>
	<string>$(DEV_DEVICE_API_BASE_URL)</string>
	<key>DistributionChannel</key>
	<string>$(DISTRIBUTION_CHANNEL)</string>
	<key>GIDClientID</key>
	<string>$(GOOGLE_CLIENT_ID)</string>
	<key>GoogleReverseClientID</key>
	<string>$(GOOGLE_REVERSED_CLIENT_ID)</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>개발 중 로컬 서버와 통신하기 위해 같은 네트워크의 Mac에 연결합니다.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>192.168.0.36</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			<key>127.0.0.1</key>
			<dict>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
			<key>localhost</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>PrivacyPolicyURL</key>
	<string>$(PRIVACY_POLICY_URL)</string>
	<key>SupportEmail</key>
	<string>$(SUPPORT_EMAIL)</string>
	<key>TermsOfServiceURL</key>
	<string>$(TERMS_OF_SERVICE_URL)</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>WidgetAppGroupIdentifier</key>
	<string>$(WIDGET_APP_GROUP_IDENTIFIER)</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
</dict>
</plist>
