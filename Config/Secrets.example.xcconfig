// Copy this file to Config/Secrets.xcconfig and fill in local-only values.
// Config/Secrets.xcconfig is gitignored and must never be committed.
//
// Client-safe and environment-specific values
GOOGLE_CLIENT_ID = YOUR_GOOGLE_CLIENT_ID
GOOGLE_REVERSED_CLIENT_ID = YOUR_GOOGLE_REVERSED_CLIENT_ID
WIDGET_APP_GROUP_IDENTIFIER = group.com.hwb.GamePedia.widget
// Optional local override for Xcode local testing: API_ENVIRONMENT = dev
URL_SCHEME_SEPARATOR = /
TERMS_OF_SERVICE_URL = https:$(URL_SCHEME_SEPARATOR)$(URL_SCHEME_SEPARATOR)your-service.example.com/terms
PRIVACY_POLICY_URL = https:$(URL_SCHEME_SEPARATOR)$(URL_SCHEME_SEPARATOR)your-service.example.com/privacy
COMMUNITY_GUIDELINES_URL = https:$(URL_SCHEME_SEPARATOR)$(URL_SCHEME_SEPARATOR)your-service.example.com/community-guidelines
SUPPORT_EMAIL = support@your-service.example.com
//
// Do not place Twitch/IGDB client secrets, SMTP credentials, translation provider
// secrets, or any backend private secret in the iOS client.
// IGDB token exchange must be handled by the backend.
