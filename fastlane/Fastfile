require "shellwords"
require "xcodeproj"

default_platform(:ios)

platform :ios do
  def xcode_container_options
    if File.exist?("GamePedia.xcworkspace")
      { workspace: "GamePedia.xcworkspace" }
    else
      { project: "GamePedia.xcodeproj" }
    end
  end

  def project_path
    "GamePedia.xcodeproj"
  end

  def app_target_name
    "GamePedia"
  end

  def distribution_team_id
    "63SB2B8YJ5"
  end

  def widget_extension_app_identifier
    "com.hwb.GamePedia.widget"
  end

  def widget_extension_target_name
    "GamePediaWidgetExtension"
  end

  def versioned_target_names
    [app_target_name, widget_extension_target_name]
  end

  def version_format_regex
    /^\d+(\.\d+){0,2}$/
  end

  def xcodebuild_container_arguments
    if File.exist?("GamePedia.xcworkspace")
      "-workspace #{Shellwords.escape("GamePedia.xcworkspace")}"
    else
      "-project #{Shellwords.escape(project_path)}"
    end
  end

  def required_env!(key)
    value = ENV[key]
    UI.user_error!("Missing required environment variable: #{key}") if value.to_s.strip.empty?
    value
  end

  def resolve_app_identifier
    value = ENV["APP_STORE_APP_IDENTIFIER"] || ENV["APP_IDENTIFIER"]
    UI.user_error!("Missing required environment variable: APP_STORE_APP_IDENTIFIER or APP_IDENTIFIER") if value.to_s.strip.empty?
    value
  end

  def resolve_app_provisioning_profile_name
    value = ENV["APP_STORE_PROVISIONING_PROFILE_NAME"].to_s.strip
    value.empty? ? "GamePedia App Store Connect" : value
  end

  def resolve_widget_provisioning_profile_name
    value = ENV["APP_STORE_WIDGET_PROVISIONING_PROFILE_NAME"].to_s.strip
    value.empty? ? "GamePedia Widget App Store Connect" : value
  end

  def option_or_env_value(options, option_key, env_key)
    option_value = options[option_key].to_s.strip
    return option_value unless option_value.empty?

    ENV[env_key].to_s.strip
  end

  def target_named!(project, target_name)
    target = project.targets.find { |item| item.name == target_name }
    UI.user_error!("Missing target #{target_name} in #{project_path}") unless target
    target
  end

  def configuration_named!(target, configuration_name)
    configuration = target.build_configurations.find { |item| item.name == configuration_name }
    UI.user_error!("Missing configuration #{configuration_name} for target #{target.name}") unless configuration
    configuration
  end

  def read_target_versioning(target_name:, configuration_name:)
    project = Xcodeproj::Project.open(project_path)
    target = target_named!(project, target_name)
    configuration = configuration_named!(target, configuration_name)

    {
      marketing_version: configuration.build_settings["MARKETING_VERSION"].to_s.strip,
      build_number: configuration.build_settings["CURRENT_PROJECT_VERSION"].to_s.strip
    }
  end

  def validate_marketing_version!(version)
    UI.user_error!("MARKETING_VERSION must use A, A.B, or A.B.C format") unless version.match?(version_format_regex)
    version
  end

  def validate_build_number!(build_number)
    UI.user_error!("CURRENT_PROJECT_VERSION must be a positive integer") unless build_number.match?(/^\d+$/)
    build_number
  end

  def current_marketing_version(configuration_name:)
    settings = read_target_versioning(
      target_name: app_target_name,
      configuration_name: configuration_name
    )
    validate_marketing_version!(settings[:marketing_version])
  end

  def current_build_number(configuration_name:)
    settings = read_target_versioning(
      target_name: app_target_name,
      configuration_name: configuration_name
    )
    validate_build_number!(settings[:build_number])
  end

  def bumped_marketing_version(current_version, bump_type)
    validate_marketing_version!(current_version)

    version_parts = current_version.split(".").map(&:to_i)

    case bump_type
    when "patch"
      UI.user_error!("Patch bump requires MARKETING_VERSION in A.B.C format") if version_parts.count < 3
      version_parts[2] += 1
    when "minor"
      UI.user_error!("Minor bump requires MARKETING_VERSION in A.B or A.B.C format") if version_parts.count < 2
      version_parts[1] += 1
      version_parts[2] = 0 if version_parts[2]
    when "major"
      version_parts[0] += 1
      version_parts[1] = 0 if version_parts[1]
      version_parts[2] = 0 if version_parts[2]
    else
      UI.user_error!("Unsupported bump type: #{bump_type}")
    end

    version_parts.join(".")
  end

  def update_managed_versioning!(marketing_version: nil, build_number: nil)
    normalized_marketing_version = marketing_version.to_s.strip
    normalized_build_number = build_number.to_s.strip

    UI.user_error!("Nothing to update in versioning state") if normalized_marketing_version.empty? && normalized_build_number.empty?

    project = Xcodeproj::Project.open(project_path)

    versioned_target_names.each do |target_name|
      target = target_named!(project, target_name)

      target.build_configurations.each do |configuration|
        configuration.build_settings["MARKETING_VERSION"] = normalized_marketing_version unless normalized_marketing_version.empty?
        configuration.build_settings["CURRENT_PROJECT_VERSION"] = normalized_build_number unless normalized_build_number.empty?
      end
    end

    project.save
  end

  def log_project_versioning!(label:, configuration_name:)
    UI.message(label)

    versioned_target_names.each do |target_name|
      settings = read_target_versioning(
        target_name: target_name,
        configuration_name: configuration_name
      )

      UI.message("[project] #{target_name} #{configuration_name}: MARKETING_VERSION=#{settings[:marketing_version]} CURRENT_PROJECT_VERSION=#{settings[:build_number]}")
    end
  end

  def log_effective_xcodebuild_versioning!(configuration_name:)
    versioned_target_names.each do |target_name|
      output = sh(
        [
          "xcodebuild",
          xcodebuild_container_arguments,
          "-target #{Shellwords.escape(target_name)}",
          "-configuration #{Shellwords.escape(configuration_name)}",
          "-showBuildSettings"
        ].join(" "),
        log: false
      )

      output.lines.grep(/TARGET_NAME =|MARKETING_VERSION =|CURRENT_PROJECT_VERSION =/).each do |line|
        UI.message("[xcodebuild] #{line.strip}")
      end
    end
  end

  def apply_versioning_and_log!(marketing_version:, build_number:, configuration_name:, context_label:)
    update_managed_versioning!(
      marketing_version: marketing_version,
      build_number: build_number
    )

    log_project_versioning!(
      label: "#{context_label} versioning prepared",
      configuration_name: configuration_name
    )

    log_effective_xcodebuild_versioning!(configuration_name: configuration_name)
  end

  def app_store_connect_api_key_from_env
    key_id = ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"] || ENV["APP_STORE_CONNECT_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] || ENV["APP_STORE_CONNECT_ISSUER_ID"]
    raw_key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"] || ENV["APP_STORE_CONNECT_PRIVATE_KEY"]
    base64_key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT_BASE64"] || ENV["APP_STORE_CONNECT_PRIVATE_KEY_BASE64"]
    key_content = raw_key_content.to_s.empty? ? base64_key_content : raw_key_content

    UI.user_error!("Missing required environment variable: APP_STORE_CONNECT_API_KEY_CONTENT / APP_STORE_CONNECT_PRIVATE_KEY or APP_STORE_CONNECT_API_KEY_CONTENT_BASE64 / APP_STORE_CONNECT_PRIVATE_KEY_BASE64") if key_content.to_s.strip.empty?
    UI.user_error!("Missing required environment variable: APP_STORE_CONNECT_API_KEY_KEY_ID or APP_STORE_CONNECT_KEY_ID") if key_id.to_s.strip.empty?
    UI.user_error!("Missing required environment variable: APP_STORE_CONNECT_API_KEY_ISSUER_ID or APP_STORE_CONNECT_ISSUER_ID") if issuer_id.to_s.strip.empty?

    app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      is_key_content_base64: raw_key_content.to_s.strip.empty?,
      in_house: false
    )
  end

  def distribution_xcargs(widget_profile_name)
    [
      'CODE_SIGN_STYLE=Manual',
      "DEVELOPMENT_TEAM=#{distribution_team_id}",
      'CODE_SIGN_IDENTITY="Apple Distribution"',
      "WIDGET_PROVISIONING_PROFILE_SPECIFIER=#{Shellwords.escape(widget_profile_name)}"
    ].join(" ")
  end

  def distribution_export_options(app_identifier, app_profile_name, widget_profile_name)
    {
      signingStyle: "manual",
      teamID: distribution_team_id,
      provisioningProfiles: {
        app_identifier => app_profile_name,
        widget_extension_app_identifier => widget_profile_name
      },
      method: "app-store"
    }
  end

  def resolved_beta_marketing_version(options)
    explicit_version_number = options[:version_number].to_s.strip
    bump_marketing = options[:bump_marketing].to_s == "true"
    bump_type = options[:bump_type].to_s.strip
    normalized_bump_type = %w[patch minor major].include?(bump_type) ? bump_type : "patch"
    current_version = current_marketing_version(configuration_name: "Staging")

    if !explicit_version_number.empty?
      validate_marketing_version!(explicit_version_number)
      UI.message("Using explicit MARKETING_VERSION #{explicit_version_number} for staging beta")
      return explicit_version_number
    end

    unless bump_marketing
      UI.message("Keeping existing MARKETING_VERSION #{current_version} for staging beta")
      return current_version
    end

    new_version = bumped_marketing_version(current_version, normalized_bump_type)
    UI.message("Auto bumped MARKETING_VERSION to #{new_version} (#{normalized_bump_type}) for staging beta")
    new_version
  end

  def next_app_store_build_number(api_key:, app_identifier:, version:)
    latest_build_number = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: app_identifier,
      version: version,
      initial_build_number: 0
    )

    next_build_number = latest_build_number.to_i + 1
    UI.message("Resolved CURRENT_PROJECT_VERSION #{next_build_number} from App Store Connect for MARKETING_VERSION #{version}")
    next_build_number.to_s
  end

  def resolved_release_marketing_version(options)
    explicit_version_number = option_or_env_value(options, :version_number, "RELEASE_VERSION_NUMBER")

    if explicit_version_number.empty?
      version = current_marketing_version(configuration_name: "Release")
      UI.message("Keeping committed MARKETING_VERSION #{version} for production release")
      return version
    end

    validate_marketing_version!(explicit_version_number)
    UI.message("Using explicit MARKETING_VERSION #{explicit_version_number} for production release")
    explicit_version_number
  end

  def resolved_release_build_number(options, api_key:, app_identifier:, version:)
    explicit_build_number = option_or_env_value(options, :build_number, "RELEASE_BUILD_NUMBER")

    unless explicit_build_number.empty?
      validate_build_number!(explicit_build_number)
      UI.message("Using explicit CURRENT_PROJECT_VERSION #{explicit_build_number} for production release")
      return explicit_build_number
    end

    next_app_store_build_number(
      api_key: api_key,
      app_identifier: app_identifier,
      version: version
    )
  end

  desc "Build and test the iOS app for CI"
  lane :ci_build do
    run_tests(
      **xcode_container_options,
      scheme: "GamePedia-Dev",
      configuration: "Debug",
      clean: true,
      skip_testing: [
        "GamePediaUITests",
        "GamePediaUITestsLaunchTests"
      ],
      derived_data_path: "DerivedData",
      output_directory: "fastlane/test_output",
      buildlog_path: "fastlane/test_output/buildlogs",
      output_types: "junit",
      fail_build: true,
      xcargs: 'CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY=""'
    )
  end

  desc "Build the staging app and upload it to TestFlight"
  lane :beta do |options|
    api_key = app_store_connect_api_key_from_env
    app_identifier = resolve_app_identifier
    app_provisioning_profile_name = resolve_app_provisioning_profile_name
    widget_provisioning_profile_name = resolve_widget_provisioning_profile_name

    selected_marketing_version = resolved_beta_marketing_version(options)
    selected_build_number = next_app_store_build_number(
      api_key: api_key,
      app_identifier: app_identifier,
      version: selected_marketing_version
    )

    apply_versioning_and_log!(
      marketing_version: selected_marketing_version,
      build_number: selected_build_number,
      configuration_name: "Staging",
      context_label: "Staging beta"
    )

    ipa_path = build_app(
      **xcode_container_options,
      scheme: "GamePedia-Staging",
      configuration: "Staging",
      clean: true,
      export_method: "app-store",
      xcargs: distribution_xcargs(widget_provisioning_profile_name),
      export_options: distribution_export_options(
        app_identifier,
        app_provisioning_profile_name,
        widget_provisioning_profile_name
      ),
      output_directory: "build/ios",
      output_name: "GamePedia-Staging.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_identifier,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Validate the production archive path on main without uploading"
  lane :release_archive do |_options|
    widget_provisioning_profile_name = resolve_widget_provisioning_profile_name

    log_project_versioning!(
      label: "Release archive validation using committed project versioning",
      configuration_name: "Release"
    )
    log_effective_xcodebuild_versioning!(configuration_name: "Release")

    build_app(
      **xcode_container_options,
      scheme: "GamePedia-Prod",
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      xcargs: distribution_xcargs(widget_provisioning_profile_name),
      archive_path: "build/archives/GamePedia.xcarchive",
      skip_package_ipa: true,
      skip_package_pkg: true
    )
  end

  desc "Build the production app and upload it to App Store Connect only when explicitly triggered"
  lane :release_upload do |options|
    api_key = app_store_connect_api_key_from_env
    app_identifier = resolve_app_identifier
    app_provisioning_profile_name = resolve_app_provisioning_profile_name
    widget_provisioning_profile_name = resolve_widget_provisioning_profile_name

    selected_marketing_version = resolved_release_marketing_version(options)
    selected_build_number = resolved_release_build_number(
      options,
      api_key: api_key,
      app_identifier: app_identifier,
      version: selected_marketing_version
    )

    apply_versioning_and_log!(
      marketing_version: selected_marketing_version,
      build_number: selected_build_number,
      configuration_name: "Release",
      context_label: "Production release"
    )

    ipa_path = build_app(
      **xcode_container_options,
      scheme: "GamePedia-Prod",
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      xcargs: distribution_xcargs(widget_provisioning_profile_name),
      export_options: distribution_export_options(
        app_identifier,
        app_provisioning_profile_name,
        widget_provisioning_profile_name
      ),
      output_directory: "build/ios",
      output_name: "GamePedia-Prod.ipa"
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: app_identifier,
      ipa: ipa_path,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false
    )
  end
end
